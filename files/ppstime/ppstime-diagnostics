#!/usr/bin/env python3
"""Create a sanitized PPSPi support bundle."""

from __future__ import annotations

import argparse
import json
import os
import platform
import tarfile
import tempfile
from datetime import datetime, timezone
from pathlib import Path

from ppstime_core import ConfigError, parse_env_file, run_command, sanitize_config, validate_config


COMMANDS = {
    "packages.txt": [
        "dpkg-query",
        "-W",
        "-f=${binary:Package}\t${Version}\n",
        "chrony",
        "gpsd",
        "gpsd-clients",
        "pps-tools",
        "i2c-tools",
        "jq",
        "python3",
    ],
    "systemd-chrony.txt": ["systemctl", "status", "--no-pager", "chrony.service"],
    "systemd-gpsd.txt": ["systemctl", "status", "--no-pager", "gpsd.service"],
    "systemd-ppstime.txt": [
        "systemctl",
        "status",
        "--no-pager",
        "ppstime-rtc-restore.service",
        "ppstime-rtc-save.timer",
        "ppstime-healthcheck.timer",
    ],
    "chronyc-tracking.txt": ["chronyc", "tracking"],
    "chronyc-sources.txt": ["chronyc", "-n", "sources", "-v"],
    "chronyc-sourcestats.txt": ["chronyc", "-n", "sourcestats", "-v"],
    "chronyc-clients.txt": ["chronyc", "-n", "clients"],
    "journal.txt": [
        "journalctl",
        "--no-pager",
        "--since=-24hours",
        "-n",
        "500",
        "-u",
        "chrony.service",
        "-u",
        "gpsd.service",
        "-u",
        "ppstime-rtc-restore.service",
        "-u",
        "ppstime-rtc-save.service",
        "-u",
        "ppstime-healthcheck.service",
    ],
}


def write_command(path: Path, command: list[str], timeout: float = 15.0) -> None:
    result = run_command(command, timeout=timeout)
    path.write_text(
        f"$ {' '.join(command)}\nexit_code={result.returncode}\n\n"
        f"{result.stdout}{result.stderr}",
        encoding="utf-8",
    )


def relevant_boot_lines() -> str:
    boot_path = next(
        (path for path in (Path("/boot/firmware/config.txt"), Path("/boot/config.txt")) if path.exists()),
        None,
    )
    if boot_path is None:
        return "boot configuration not found\n"
    prefixes = ("enable_uart=", "dtparam=i2c", "dtoverlay=pps", "dtoverlay=i2c-rtc", "# BEGIN PPSPi", "# END PPSPi")
    lines = [line for line in boot_path.read_text(encoding="utf-8").splitlines() if line.strip().startswith(prefixes)]
    return f"# {boot_path}\n" + "\n".join(lines) + "\n"


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--config", type=Path, default=Path("/etc/ppstime/ppstime.env"))
    parser.add_argument("--output-dir", type=Path, default=Path.cwd())
    args = parser.parse_args()
    try:
        config = parse_env_file(args.config)
        validate_config(config)
    except ConfigError as exc:
        print(f"ppstime-diagnostics: {exc}")
        return 2

    timestamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    args.output_dir.mkdir(parents=True, exist_ok=True)
    archive = args.output_dir / f"ppstime-diagnostics-{timestamp}.tar.gz"
    with tempfile.TemporaryDirectory(prefix="ppstime-diagnostics-") as temporary:
        bundle = Path(temporary) / f"ppstime-diagnostics-{timestamp}"
        bundle.mkdir(mode=0o700)
        (bundle / "configuration.json").write_text(
            json.dumps(sanitize_config(config), indent=2, sort_keys=True) + "\n", encoding="utf-8"
        )
        (bundle / "boot-configuration.txt").write_text(relevant_boot_lines(), encoding="utf-8")
        model_path = Path("/proc/device-tree/model")
        model = model_path.read_text(encoding="utf-8").rstrip("\x00") if model_path.exists() else "unknown"
        metadata = {
            "generated_utc": timestamp,
            "kernel": platform.release(),
            "platform": platform.platform(),
            "raspberry_pi_model": model,
            "effective_user_id": os.geteuid(),
        }
        (bundle / "system.json").write_text(json.dumps(metadata, indent=2) + "\n", encoding="utf-8")
        devices = sorted(str(path) for pattern in ("serial*", "ttyAMA*", "ttyS*", "pps*", "rtc*") for path in Path("/dev").glob(pattern))
        (bundle / "devices.txt").write_text("\n".join(devices) + "\n", encoding="utf-8")
        for filename, command in COMMANDS.items():
            write_command(bundle / filename, command)
        write_command(bundle / "ppstest.txt", ["ppstest", config["PPS_DEVICE"]], timeout=3)
        write_command(bundle / "gpspipe.txt", ["gpspipe", "-w", "-n", "10"], timeout=10)
        write_command(
            bundle / "hwclock.txt",
            ["hwclock", "--show", "--utc", "--rtc", config["RTC_DEVICE"]],
            timeout=5,
        )
        with tarfile.open(archive, "w:gz", format=tarfile.PAX_FORMAT) as handle:
            handle.add(bundle, arcname=bundle.name, recursive=True)
    os.chmod(archive, 0o600)
    print(archive)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())