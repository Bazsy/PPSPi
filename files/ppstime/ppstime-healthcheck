#!/usr/bin/env python3
"""Run stateful PPSPi health monitoring without causing restart loops."""

from __future__ import annotations

import subprocess
from pathlib import Path


def main() -> int:
    try:
        result = subprocess.run(
            [str(Path(__file__).with_name("ppstime-health")), "--update"],
            check=False,
            timeout=65,
        )
    except (OSError, subprocess.TimeoutExpired) as exc:
        print(f"PPSPi health warning: monitor execution failed: {exc}")
        return 0
    if result.returncode != 0:
        print(f"PPSPi health warning: monitor exited {result.returncode}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
