#!/usr/bin/env python3
"""Show, validate, update, and apply PPSPi configuration."""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

from ppstime_core import CONFIG_KEYS, ConfigError, atomic_write, config_to_env, parse_env_file, validate_config


def require_root() -> None:
    if os.geteuid() != 0:
        raise ConfigError("this operation must run as root")


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--config", type=Path, default=Path("/etc/ppstime/ppstime.env"))
    subparsers = parser.add_subparsers(dest="command", required=True)
    show_parser = subparsers.add_parser("show", help="show active configuration")
    show_parser.add_argument("--json", action="store_true")
    set_parser = subparsers.add_parser("set", help="set one validated value")
    set_parser.add_argument("key")
    set_parser.add_argument("value")
    subparsers.add_parser("apply", help="regenerate configuration and restart services")
    args = parser.parse_args()

    try:
        config = parse_env_file(args.config)
        validate_config(config)
        if args.command == "show":
            if args.json:
                print(json.dumps(dict(sorted(config.items())), indent=2))
            else:
                print(config_to_env(config), end="")
            return 0
        if args.command == "set":
            require_root()
            if args.key not in CONFIG_KEYS:
                raise ConfigError(f"unsupported key {args.key!r}")
            if args.key == "PPSTIME_PROFILE":
                raise ConfigError("changing PPSTIME_PROFILE requires reinstalling with --profile")
            updated = dict(config)
            updated[args.key] = args.value
            validate_config(updated)
            atomic_write(args.config, config_to_env(updated), mode=0o644)
            print(f"Updated {args.key}; run 'ppstime-config apply' to activate it")
            return 0

        require_root()
        apply_command = [
            "/usr/lib/ppstime/configure-profile.py",
            "--source-root",
            "/usr/share/ppstime",
            "--config",
            str(args.config),
        ]
        apply_process = subprocess.run(apply_command, check=False)
        if apply_process.returncode != 0:
            return apply_process.returncode
        syntax_process = subprocess.run(
            ["chronyd", "-p", "-f", "/etc/chrony/chrony.conf"], check=False
        )
        if syntax_process.returncode != 0:
            print("Chrony validation failed; services were not restarted", file=sys.stderr)
            return 1
        subprocess.run(["systemctl", "daemon-reload"], check=True)
        for key, units in (
            ("CHRONY_ENABLED", ["chrony.service"]),
            ("GPSD_ENABLED", ["gpsd.service", "gpsd.socket"]),
        ):
            if config[key] == "true":
                subprocess.run(["systemctl", "enable", *units], check=True)
                subprocess.run(["systemctl", "restart", units[0]], check=True)
            else:
                subprocess.run(["systemctl", "disable", "--now", *units], check=True)
        rtc_units = ["ppstime-rtc-restore.service", "ppstime-rtc-save.timer"]
        if config["RTC_ENABLED"] == "true":
            subprocess.run(["systemctl", "enable", *rtc_units], check=True)
            subprocess.run(["systemctl", "start", "ppstime-rtc-save.timer"], check=True)
        else:
            subprocess.run(["systemctl", "disable", "--now", *rtc_units], check=True)
        subprocess.run(["systemctl", "enable", "--now", "ppstime-healthcheck.timer"], check=True)
        print("PPSPi configuration applied")
        return 0
    except (ConfigError, OSError, subprocess.CalledProcessError) as exc:
        print(f"ppstime-config: {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())