#!/usr/bin/env python3
"""Report passive PPSPi host health without remediation."""

from __future__ import annotations

import argparse
import json
import math
import os
import re
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

from ppstime_core import ConfigError, parse_env_file, validate_config

SCHEMA_VERSION = 1
UPDATE_SCHEMA_VERSION = 1
COMMAND_TIMEOUT_SECONDS = 5
DEFAULT_THRESHOLDS = {
    "disk_warning_percent": 15.0,
    "disk_critical_percent": 5.0,
    "inode_warning_percent": 15.0,
    "inode_critical_percent": 5.0,
    "temperature_warning_celsius": 75.0,
    "temperature_critical_celsius": 85.0,
    "update_warning_hours": 48.0,
    "update_critical_hours": 168.0,
}
THRESHOLD_KEYS = frozenset(DEFAULT_THRESHOLDS)
CONFIG_THRESHOLD_MAP = {
    "HOST_DISK_WARNING_PERCENT": "disk_warning_percent",
    "HOST_DISK_CRITICAL_PERCENT": "disk_critical_percent",
    "HOST_INODE_WARNING_PERCENT": "inode_warning_percent",
    "HOST_INODE_CRITICAL_PERCENT": "inode_critical_percent",
    "HOST_TEMPERATURE_WARNING_C": "temperature_warning_celsius",
    "HOST_TEMPERATURE_CRITICAL_C": "temperature_critical_celsius",
    "HOST_UPDATE_WARNING_HOURS": "update_warning_hours",
    "HOST_UPDATE_CRITICAL_HOURS": "update_critical_hours",
}
HOST_STATES = ("HEALTHY", "WARNING", "CRITICAL")
THROTTLE_BITS = {
    0: "under_voltage_now",
    1: "frequency_capped_now",
    2: "throttled_now",
    3: "soft_temperature_limit_now",
    16: "under_voltage_occurred",
    17: "frequency_capped_occurred",
    18: "throttling_occurred",
    19: "soft_temperature_limit_occurred",
}
CURRENT_THROTTLE_BITS = frozenset({0, 1, 2, 3})
HISTORICAL_THROTTLE_BITS = frozenset({16, 17, 18, 19})
UPDATE_KEYS = frozenset(
    {"schema_version", "last_check_utc", "last_success_utc", "result", "reboot_required"}
)
FILESYSTEM_KEYS = frozenset(
    {
        "available",
        "available_bytes",
        "available_percent",
        "inode_available_percent",
        "read_only",
        "error",
    }
)
THROTTLING_KEYS = frozenset({"available", "flags", "active", "error"})
UPDATE_OUTPUT_KEYS = frozenset(
    {
        "status",
        "last_check_utc",
        "last_success_utc",
        "success_age_seconds",
        "reboot_required",
        "error",
    }
)


class HostHealthError(ValueError):
    """Raised when host-health input is invalid."""


def utc_now() -> datetime:
    return datetime.now(timezone.utc)


def parse_timestamp(value: Any, name: str) -> datetime:
    if not isinstance(value, str):
        raise HostHealthError(f"{name} must be a UTC timestamp string")
    try:
        parsed = datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError as exc:
        raise HostHealthError(f"{name} is invalid: {value!r}") from exc
    if parsed.tzinfo is None:
        raise HostHealthError(f"{name} must include a timezone")
    return parsed.astimezone(timezone.utc)


def finite_number(value: Any, name: str) -> float:
    if type(value) not in {int, float} or not math.isfinite(value):
        raise HostHealthError(f"{name} must be a finite number")
    return float(value)


def validate_thresholds(payload: Any) -> dict[str, float]:
    if not isinstance(payload, dict) or set(payload) != THRESHOLD_KEYS:
        raise HostHealthError("host-health threshold keys do not match schema")
    thresholds = {
        key: finite_number(payload[key], f"host-health threshold {key}")
        for key in sorted(THRESHOLD_KEYS)
    }
    for prefix in ("disk", "inode"):
        warning = thresholds[f"{prefix}_warning_percent"]
        critical = thresholds[f"{prefix}_critical_percent"]
        if not 0.0 < critical < warning <= 100.0:
            raise HostHealthError(
                f"{prefix} thresholds must satisfy 0 < critical < warning <= 100"
            )
    if not (
        0.0
        < thresholds["temperature_warning_celsius"]
        < thresholds["temperature_critical_celsius"]
        <= 150.0
    ):
        raise HostHealthError("temperature thresholds are invalid")
    if not (
        0.0
        < thresholds["update_warning_hours"]
        < thresholds["update_critical_hours"]
    ):
        raise HostHealthError("update-age thresholds are invalid")
    return thresholds


def load_thresholds(path: Path | None) -> dict[str, float]:
    if path is None or not path.exists():
        return validate_thresholds(DEFAULT_THRESHOLDS)
    try:
        config = parse_env_file(path)
        validate_config(config)
        payload = {
            threshold_key: float(config[config_key])
            for config_key, threshold_key in CONFIG_THRESHOLD_MAP.items()
        }
    except (ConfigError, OSError, ValueError) as exc:
        raise HostHealthError(f"cannot read host-health thresholds: {exc}") from exc
    return validate_thresholds(payload)


def available_percent(available: int, total: int) -> float | None:
    if total <= 0:
        return None
    return 100.0 * available / total


def filesystem_status(path: Path) -> dict[str, Any]:
    try:
        status = os.statvfs(path)
    except OSError as exc:
        return {
            "available": False,
            "available_bytes": None,
            "available_percent": None,
            "inode_available_percent": None,
            "read_only": None,
            "error": type(exc).__name__,
        }
    available_bytes = status.f_bavail * status.f_frsize
    total_bytes = status.f_blocks * status.f_frsize
    return {
        "available": True,
        "available_bytes": available_bytes,
        "available_percent": available_percent(available_bytes, total_bytes),
        "inode_available_percent": available_percent(status.f_favail, status.f_files),
        "read_only": bool(status.f_flag & getattr(os, "ST_RDONLY", 1)),
        "error": None,
    }


def mounted_paths(mountinfo: Path) -> set[Path]:
    try:
        lines = mountinfo.read_text(encoding="utf-8").splitlines()
    except OSError:
        return set()
    result: set[Path] = set()
    for line in lines:
        fields = line.split()
        if len(fields) >= 6:
            result.add(Path(unescape_mount_path(fields[4])))
    return result


def find_boot_path(candidates: list[Path], mountinfo: Path) -> Path | None:
    mounts = mounted_paths(mountinfo)
    return next((path for path in candidates if path in mounts and path.is_dir()), None)


def read_temperature(thermal_root: Path) -> float | None:
    candidates: list[tuple[int, Path]] = []
    for zone in thermal_root.glob("thermal_zone*"):
        try:
            zone_type = (zone / "type").read_text(encoding="ascii").strip().lower()
        except (OSError, UnicodeError):
            zone_type = ""
        priority = 0 if zone_type in {"cpu-thermal", "cpu_thermal"} else 1
        candidates.append((priority, zone))
    for _, zone in sorted(candidates, key=lambda item: (item[0], item[1].name)):
        try:
            raw = (zone / "temp").read_text(encoding="ascii").strip()
            value = int(raw) / 1000.0
        except (OSError, UnicodeError, ValueError):
            continue
        if math.isfinite(value) and -40.0 <= value <= 150.0:
            return value
    return None


def parse_throttled(text: str) -> dict[str, Any]:
    match = re.fullmatch(r"\s*throttled=(0x[0-9a-fA-F]+)\s*", text)
    if not match:
        raise HostHealthError("vcgencmd returned an invalid throttled value")
    flags = int(match.group(1), 16)
    active = [name for bit, name in THROTTLE_BITS.items() if flags & (1 << bit)]
    return {"available": True, "flags": flags, "active": active, "error": None}


def read_throttling(command: Path) -> dict[str, Any]:
    try:
        result = subprocess.run(
            [str(command), "get_throttled"],
            capture_output=True,
            check=False,
            text=True,
            timeout=COMMAND_TIMEOUT_SECONDS,
        )
    except (OSError, subprocess.TimeoutExpired) as exc:
        return {"available": False, "flags": None, "active": [], "error": type(exc).__name__}
    if result.returncode != 0:
        return {
            "available": False,
            "flags": None,
            "active": [],
            "error": f"exit_{result.returncode}",
        }
    try:
        return parse_throttled(result.stdout)
    except HostHealthError:
        return {"available": False, "flags": None, "active": [], "error": "invalid_output"}


def unescape_mount_path(value: str) -> str:
    return re.sub(
        r"\\([0-7]{3})",
        lambda match: chr(int(match.group(1), 8)),
        value,
    )


def root_device_id(mountinfo: Path) -> str | None:
    try:
        lines = mountinfo.read_text(encoding="utf-8").splitlines()
    except OSError:
        return None
    for line in lines:
        fields = line.split()
        if len(fields) >= 6 and unescape_mount_path(fields[4]) == "/":
            return fields[2] if re.fullmatch(r"[0-9]+:[0-9]+", fields[2]) else None
    return None


def read_ext4_errors(
    mountinfo: Path,
    sys_dev_block: Path,
    sys_fs_ext4: Path,
) -> int | None:
    device_id = root_device_id(mountinfo)
    if device_id is None:
        return None
    device_link = sys_dev_block / device_id
    try:
        device_name = device_link.resolve(strict=True).name
        raw = (sys_fs_ext4 / device_name / "errors_count").read_text(
            encoding="ascii"
        ).strip()
        errors = int(raw)
    except (OSError, UnicodeError, ValueError):
        return None
    return errors if errors >= 0 else None


def unknown_update_state() -> dict[str, Any]:
    return {
        "status": "UNKNOWN",
        "last_check_utc": None,
        "last_success_utc": None,
        "success_age_seconds": None,
        "reboot_required": None,
        "error": None,
    }


def read_update_state(path: Path, now: datetime) -> dict[str, Any]:
    if not path.exists():
        return unknown_update_state()
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        result = unknown_update_state()
        result["error"] = type(exc).__name__
        return result
    if not isinstance(payload, dict) or set(payload) != UPDATE_KEYS:
        result = unknown_update_state()
        result["error"] = "schema"
        return result
    if type(payload["schema_version"]) is not int or payload["schema_version"] != 1:
        result = unknown_update_state()
        result["error"] = "schema"
        return result
    if payload["result"] not in {"SUCCESS", "FAILED"} or not isinstance(
        payload["reboot_required"], bool
    ):
        result = unknown_update_state()
        result["error"] = "schema"
        return result
    try:
        checked = parse_timestamp(payload["last_check_utc"], "last_check_utc")
        success = (
            parse_timestamp(payload["last_success_utc"], "last_success_utc")
            if payload["last_success_utc"] is not None
            else None
        )
    except HostHealthError:
        result = unknown_update_state()
        result["error"] = "timestamp"
        return result
    if payload["result"] == "SUCCESS" and success is None:
        result = unknown_update_state()
        result["error"] = "missing_success"
        return result
    if checked > now or (success is not None and (success > checked or success > now)):
        result = unknown_update_state()
        result["error"] = "timestamp_order"
        return result
    age = (now - success).total_seconds() if success is not None else None
    return {
        "status": payload["result"],
        "last_check_utc": checked.strftime("%Y-%m-%dT%H:%M:%SZ"),
        "last_success_utc": (
            success.strftime("%Y-%m-%dT%H:%M:%SZ") if success is not None else None
        ),
        "success_age_seconds": age,
        "reboot_required": payload["reboot_required"],
        "error": None,
    }


def classify_host(
    payload: dict[str, Any], thresholds: dict[str, float] | None = None
) -> tuple[str, list[str]]:
    threshold = thresholds or validate_thresholds(DEFAULT_THRESHOLDS)
    critical: list[str] = []
    warning: list[str] = []
    filesystems = payload["filesystems"]
    for name in ("root", "boot"):
        filesystem = filesystems[name]
        if not filesystem["available"]:
            critical.append(f"{name}_filesystem_unavailable")
            continue
        if filesystem["read_only"]:
            critical.append(f"{name}_filesystem_read_only")
        available = filesystem["available_percent"]
        inode_available = filesystem["inode_available_percent"]
        if available is not None:
            if available <= threshold["disk_critical_percent"]:
                critical.append(f"{name}_disk_critical")
            elif available <= threshold["disk_warning_percent"]:
                warning.append(f"{name}_disk_low")
        if inode_available is not None:
            if inode_available <= threshold["inode_critical_percent"]:
                critical.append(f"{name}_inodes_critical")
            elif inode_available <= threshold["inode_warning_percent"]:
                warning.append(f"{name}_inodes_low")

    temperature = payload["temperature_celsius"]
    if temperature is None:
        warning.append("temperature_unavailable")
    elif temperature >= threshold["temperature_critical_celsius"]:
        critical.append("temperature_critical")
    elif temperature >= threshold["temperature_warning_celsius"]:
        warning.append("temperature_high")

    throttling = payload["throttling"]
    if not throttling["available"]:
        warning.append("throttling_unavailable")
    else:
        flags = throttling["flags"]
        if any(flags & (1 << bit) for bit in CURRENT_THROTTLE_BITS):
            critical.append("throttling_active")
        elif any(flags & (1 << bit) for bit in HISTORICAL_THROTTLE_BITS):
            warning.append("throttling_occurred")

    filesystem_errors = payload["root_filesystem_errors"]
    if filesystem_errors is not None and filesystem_errors > 0:
        critical.append("root_filesystem_errors")

    updates = payload["updates"]
    update_age = updates["success_age_seconds"]
    if updates["error"] is not None:
        warning.append("update_state_invalid")
    elif updates["status"] == "FAILED":
        warning.append("update_check_failed")
    if update_age is not None:
        if update_age >= threshold["update_critical_hours"] * 3600:
            critical.append("update_success_stale_critical")
        elif update_age >= threshold["update_warning_hours"] * 3600:
            warning.append("update_success_stale")
    if updates["reboot_required"]:
        warning.append("update_reboot_required")

    if critical:
        return "CRITICAL", critical + warning
    if warning:
        return "WARNING", warning
    return "HEALTHY", []


def validate_fixture(payload: Any) -> dict[str, Any]:
    if not isinstance(payload, dict):
        raise HostHealthError("host-health fixture must be an object")
    required = {
        "filesystems",
        "temperature_celsius",
        "throttling",
        "root_filesystem_errors",
        "updates",
    }
    if set(payload) != required:
        raise HostHealthError("host-health fixture keys do not match schema")
    filesystems = payload["filesystems"]
    if not isinstance(filesystems, dict) or set(filesystems) != {"root", "boot"}:
        raise HostHealthError("host-health filesystems must contain root and boot")
    for name, filesystem in filesystems.items():
        if not isinstance(filesystem, dict) or set(filesystem) != FILESYSTEM_KEYS:
            raise HostHealthError(f"host-health {name} filesystem must be an object")
        for key in ("available", "read_only"):
            if filesystem.get(key) is not None and not isinstance(filesystem[key], bool):
                raise HostHealthError(f"host-health {name}.{key} must be boolean or null")
        for key in ("available_bytes", "available_percent", "inode_available_percent"):
            value = filesystem.get(key)
            if value is not None:
                finite_number(value, f"host-health {name}.{key}")
    temperature = payload["temperature_celsius"]
    if temperature is not None:
        finite_number(temperature, "host-health temperature_celsius")
    throttling = payload["throttling"]
    if not isinstance(throttling, dict) or set(throttling) != THROTTLING_KEYS:
        raise HostHealthError("host-health throttling must be an object")
    if not isinstance(throttling.get("available"), bool):
        raise HostHealthError("host-health throttling.available must be boolean")
    flags = throttling.get("flags")
    if flags is not None and (type(flags) is not int or flags < 0):
        raise HostHealthError("host-health throttling.flags must be a non-negative integer")
    active = throttling.get("active")
    if not isinstance(active, list) or not all(isinstance(value, str) for value in active):
        raise HostHealthError("host-health throttling.active must contain strings")
    errors = payload["root_filesystem_errors"]
    if errors is not None and (type(errors) is not int or errors < 0):
        raise HostHealthError("host-health root_filesystem_errors is invalid")
    updates = payload["updates"]
    if not isinstance(updates, dict) or set(updates) != UPDATE_OUTPUT_KEYS:
        raise HostHealthError("host-health updates must be an object")
    if updates["status"] not in {"UNKNOWN", "SUCCESS", "FAILED"}:
        raise HostHealthError("host-health updates.status is invalid")
    if updates["reboot_required"] is not None and not isinstance(
        updates["reboot_required"], bool
    ):
        raise HostHealthError("host-health updates.reboot_required is invalid")
    age = updates.get("success_age_seconds")
    if age is not None:
        finite_number(age, "host-health updates.success_age_seconds")
    return payload


def collect_host_health(args: argparse.Namespace, now: datetime) -> dict[str, Any]:
    boot_path = find_boot_path(args.boot_paths, args.mountinfo)
    filesystems = {
        "root": filesystem_status(args.root_path),
        "boot": (
            filesystem_status(boot_path)
            if boot_path is not None
            else {
                "available": False,
                "available_bytes": None,
                "available_percent": None,
                "inode_available_percent": None,
                "read_only": None,
                "error": "not_found",
            }
        ),
    }
    return {
        "filesystems": filesystems,
        "temperature_celsius": read_temperature(args.thermal_root),
        "throttling": read_throttling(args.vcgencmd),
        "root_filesystem_errors": read_ext4_errors(
            args.mountinfo, args.sys_dev_block, args.sys_fs_ext4
        ),
        "updates": read_update_state(args.update_state, now),
    }


def render_human(payload: dict[str, Any]) -> str:
    lines = ["PPSPi host health", "------------------", "", f"State: {payload['state']}"]
    reasons = payload["reasons"]
    lines.append(f"Reasons: {', '.join(reasons) if reasons else 'none'}")
    for name in ("root", "boot"):
        filesystem = payload["filesystems"][name]
        lines.append(
            f"{name.title()} free: "
            f"{filesystem['available_percent']:.1f}%"
            if filesystem["available_percent"] is not None
            else f"{name.title()} free: unavailable"
        )
    temperature = payload["temperature_celsius"]
    lines.append(
        f"Temperature: {temperature:.1f} C"
        if temperature is not None
        else "Temperature: unavailable"
    )
    flags = payload["throttling"]["flags"]
    lines.append(
        f"Throttling flags: {flags:#x}"
        if flags is not None
        else "Throttling flags: unavailable"
    )
    errors = payload["root_filesystem_errors"]
    lines.append(
        f"Root filesystem errors: {errors}"
        if errors is not None
        else "Root filesystem errors: unavailable"
    )
    updates = payload["updates"]
    lines.append(f"Update status: {updates['status']}")
    return "\n".join(lines)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--fixture-json", type=Path, help=argparse.SUPPRESS)
    parser.add_argument(
        "--thresholds",
        type=Path,
        default=Path("/etc/ppstime/ppstime.env"),
        help=argparse.SUPPRESS,
    )
    parser.add_argument("--now", help=argparse.SUPPRESS)
    parser.add_argument("--root-path", type=Path, default=Path("/"), help=argparse.SUPPRESS)
    parser.add_argument(
        "--boot-path",
        dest="boot_paths",
        action="append",
        type=Path,
        default=None,
        help=argparse.SUPPRESS,
    )
    parser.add_argument(
        "--thermal-root",
        type=Path,
        default=Path("/sys/class/thermal"),
        help=argparse.SUPPRESS,
    )
    parser.add_argument(
        "--vcgencmd", type=Path, default=Path("/usr/bin/vcgencmd"), help=argparse.SUPPRESS
    )
    parser.add_argument(
        "--mountinfo",
        type=Path,
        default=Path("/proc/self/mountinfo"),
        help=argparse.SUPPRESS,
    )
    parser.add_argument(
        "--sys-dev-block",
        type=Path,
        default=Path("/sys/dev/block"),
        help=argparse.SUPPRESS,
    )
    parser.add_argument(
        "--sys-fs-ext4",
        type=Path,
        default=Path("/sys/fs/ext4"),
        help=argparse.SUPPRESS,
    )
    parser.add_argument(
        "--update-state",
        type=Path,
        default=Path("/var/lib/ppstime/os-update-state.json"),
        help=argparse.SUPPRESS,
    )
    args = parser.parse_args()
    if args.boot_paths is None:
        args.boot_paths = [Path("/boot/firmware"), Path("/boot")]
    return args


def main() -> int:
    args = parse_args()
    try:
        now = parse_timestamp(args.now, "now") if args.now else utc_now()
        thresholds = load_thresholds(args.thresholds)
        if args.fixture_json is not None:
            payload = validate_fixture(json.loads(args.fixture_json.read_text(encoding="utf-8")))
        else:
            payload = collect_host_health(args, now)
        state, reasons = classify_host(payload, thresholds)
        result = {"schema_version": SCHEMA_VERSION, "state": state, "reasons": reasons, **payload}
        if args.json:
            print(json.dumps(result, indent=2, sort_keys=True, allow_nan=False))
        else:
            print(render_human(result))
        return 0
    except (HostHealthError, OSError, json.JSONDecodeError) as exc:
        print(f"ppstime-host-health: {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
