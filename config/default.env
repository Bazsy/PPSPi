# PPSPi defaults. Values in a selected hardware profile override this file.
# A custom --config file and explicitly exported variables override both.

PPSTIME_PROFILE=uputronics-gps-rtc-hat

GPS_DEVICE=/dev/serial0
GPS_BAUD=9600
GPSD_ENABLED=true
GPSD_OPTIONS=-n

PPS_DEVICE=/dev/pps0
PPS_GPIO=18
PPS_ASSERT_EDGE=rising

RTC_ENABLED=true
RTC_OVERLAY=rv3028
RTC_DEVICE=/dev/rtc0

# Comma-separated CIDRs accepted by Chrony. This RFC1918 default is intended
# for first boot and should be narrowed with ppstime-config for each LAN.
NTP_ALLOW=192.168.0.0/16
NTP_FALLBACK_POOL=pool.ntp.org

# Serial-message latency is hardware/firmware dependent. Keep the GPS source
# unselected by default and use it only to label PPS seconds. Calibrate before
# changing this value.
CHRONY_GPS_OFFSET=0.0
CHRONY_ENABLED=true

SSH_ENABLED=false
DEFAULT_HOSTNAME=ppspi

# The first milestone is intentionally limited to Raspberry Pi 4 Model B.
SUPPORTED_MODEL_PATTERN='^Raspberry Pi 4 Model B Rev [0-9.]+$'