# Uputronics GPS/RTC Expansion Board for Raspberry Pi (current RV-3028-C7
# revision). Sources and revision caveats are documented in docs/hardware.md.

PPSTIME_PROFILE=uputronics-gps-rtc-hat

# Header pins 8/10: BCM GPIO 14/15 via Raspberry Pi's stable serial alias.
GPS_DEVICE=/dev/serial0
GPS_BAUD=9600

# Header pin 12: BCM GPIO 18, active on the rising edge.
PPS_DEVICE=/dev/pps0
PPS_GPIO=18
PPS_ASSERT_EDGE=rising

# Micro Crystal RV-3028-C7 on I2C address 0x52.
RTC_ENABLED=true
RTC_OVERLAY=rv3028
RTC_DEVICE=/dev/rtc0